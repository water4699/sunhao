<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.promotion.mapper.PromotionMapper">
    
    <resultMap type="Promotion" id="PromotionResult">
        <result property="promotionId"    column="promotion_id"    />
        <result property="title"    column="title"    />
        <result property="description"    column="description"    />
        <result property="discountType"    column="discount_type"    />
        <result property="discountValue"    column="discount_value"    />
        <result property="startDate"    column="start_date"    />
        <result property="endDate"    column="end_date"    />
        <result property="applicableTo"    column="applicable_to"    />
        <result property="usageLimit"    column="usage_limit"    />
        <result property="status"    column="status"    />
        <result property="createdAt"    column="created_at"    />
    </resultMap>

    <sql id="selectPromotionVo">
        select promotion_id, title, description, discount_type, discount_value, start_date, end_date, applicable_to, usage_limit, status, created_at from promotion
    </sql>

    <select id="selectPromotionList" parameterType="Promotion" resultMap="PromotionResult">
        <include refid="selectPromotionVo"/>
        <where>  
            <if test="title != null  and title != ''"> and title = #{title}</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="discountType != null  and discountType != ''"> and discount_type = #{discountType}</if>
            <if test="discountValue != null "> and discount_value = #{discountValue}</if>
            <if test="startDate != null "> and start_date = #{startDate}</if>
            <if test="endDate != null "> and end_date = #{endDate}</if>
            <if test="applicableTo != null  and applicableTo != ''"> and applicable_to = #{applicableTo}</if>
            <if test="usageLimit != null  and usageLimit != ''"> and usage_limit = #{usageLimit}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="createdAt != null "> and created_at = #{createdAt}</if>
        </where>
    </select>
    
    <select id="selectPromotionByPromotionId" parameterType="String" resultMap="PromotionResult">
        <include refid="selectPromotionVo"/>
        where promotion_id = #{promotionId}
    </select>

    <insert id="insertPromotion" parameterType="Promotion" useGeneratedKeys="true" keyProperty="promotionId">
        insert into promotion
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="description != null and description != ''">description,</if>
            <if test="discountType != null and discountType != ''">discount_type,</if>
            <if test="discountValue != null">discount_value,</if>
            <if test="startDate != null">start_date,</if>
            <if test="endDate != null">end_date,</if>
            <if test="applicableTo != null and applicableTo != ''">applicable_to,</if>
            <if test="usageLimit != null">usage_limit,</if>
            <if test="status != null">status,</if>
            <if test="createdAt != null">created_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="description != null and description != ''">#{description},</if>
            <if test="discountType != null and discountType != ''">#{discountType},</if>
            <if test="discountValue != null">#{discountValue},</if>
            <if test="startDate != null">#{startDate},</if>
            <if test="endDate != null">#{endDate},</if>
            <if test="applicableTo != null and applicableTo != ''">#{applicableTo},</if>
            <if test="usageLimit != null">#{usageLimit},</if>
            <if test="status != null">#{status},</if>
            <if test="createdAt != null">#{createdAt},</if>
         </trim>
    </insert>

    <update id="updatePromotion" parameterType="Promotion">
        update promotion
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="description != null and description != ''">description = #{description},</if>
            <if test="discountType != null and discountType != ''">discount_type = #{discountType},</if>
            <if test="discountValue != null">discount_value = #{discountValue},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="applicableTo != null and applicableTo != ''">applicable_to = #{applicableTo},</if>
            <if test="usageLimit != null">usage_limit = #{usageLimit},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
        </trim>
        where promotion_id = #{promotionId}
    </update>

    <delete id="deletePromotionByPromotionId" parameterType="String">
        delete from promotion where promotion_id = #{promotionId}
    </delete>

    <delete id="deletePromotionByPromotionIds" parameterType="String">
        delete from promotion where promotion_id in 
        <foreach item="promotionId" collection="array" open="(" separator="," close=")">
            #{promotionId}
        </foreach>
    </delete>
</mapper>