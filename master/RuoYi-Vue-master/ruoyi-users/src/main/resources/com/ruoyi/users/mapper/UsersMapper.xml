<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.users.mapper.UsersMapper">
    
    <resultMap type="Users" id="UsersResult">
        <result property="usersId"    column="users_id"    />
        <result property="usersname"    column="usersname"    />
        <result property="phone"    column="phone"    />
        <result property="usersType"    column="users_type"    />
        <result property="image"    column="image"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <resultMap type="Users" id="UsersAuthResult" extends="UsersResult">
        <result property="password" column="password" />
    </resultMap>

    <sql id="selectUsersVo">
        select users_id, usersname, phone, users_type, image, status, create_time from users
    </sql>

    <sql id="selectUsersVoAuth">
        select users_id, usersname, phone, password, users_type, image, status, create_time from users
    </sql>

    <select id="selectUsersList" parameterType="Users" resultMap="UsersResult">
        <include refid="selectUsersVo"/>
        <where>  
            <if test="usersname != null  and usersname != ''"> and usersname like concat('%', #{usersname}, '%')</if>
            <if test="phone != null  and phone != ''"> and phone = #{phone}</if>
            <if test="usersType != null  and usersType != ''"> and users_type = #{usersType}</if>
            <if test="image != null  and image != ''"> and image = #{image}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectUsersByUsersId" parameterType="String" resultMap="UsersResult">
        <include refid="selectUsersVo"/>
        where users_id = #{usersId}
    </select>

    <select id="selectUsersByUsersnameForAuth" parameterType="String" resultMap="UsersAuthResult">
        <include refid="selectUsersVoAuth"/>
        where usersname = #{usersname} limit 1
    </select>

    <select id="selectUsersByPhoneForAuth" parameterType="String" resultMap="UsersAuthResult">
        <include refid="selectUsersVoAuth"/>
        where phone = #{phone} limit 1
    </select>

    <select id="countUsersByUsersname" parameterType="String" resultType="int">
        select count(1) from users where usersname = #{usersname}
    </select>

    <select id="countUsersByPhone" parameterType="String" resultType="int">
        select count(1) from users where phone = #{phone}
    </select>

    <insert id="insertUsers" parameterType="Users" useGeneratedKeys="true" keyProperty="usersId" keyColumn="users_id">
        insert into users
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="usersname != null and usersname != ''">usersname,</if>
            <if test="phone != null and phone != ''">phone,</if>
            <if test="password != null and password != ''">password,</if>
            <if test="usersType != null and usersType != ''">users_type,</if>
            <if test="image != null">image,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="usersname != null and usersname != ''">#{usersname},</if>
            <if test="phone != null and phone != ''">#{phone},</if>
            <if test="password != null and password != ''">#{password},</if>
            <if test="usersType != null and usersType != ''">#{usersType},</if>
            <if test="image != null">#{image},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateUsers" parameterType="Users">
        update users
        <trim prefix="SET" suffixOverrides=",">
            <if test="usersname != null and usersname != ''">usersname = #{usersname},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="password != null and password != ''">password = #{password},</if>
            <if test="usersType != null and usersType != ''">users_type = #{usersType},</if>
            <if test="image != null and image != ''">image = #{image},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where users_id = #{usersId}
    </update>

    <delete id="deleteUsersByUsersId" parameterType="String">
        delete from users where users_id = #{usersId}
    </delete>

    <delete id="deleteUsersByUsersIds" parameterType="String">
        delete from users where users_id in 
        <foreach item="usersId" collection="array" open="(" separator="," close=")">
            #{usersId}
        </foreach>
    </delete>
</mapper>