<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.classroom.mapper.ClassroomMapper">
    
    <resultMap type="Classroom" id="ClassroomResult">
        <result property="classroomId"    column="classroom_id"    />
        <result property="name"    column="name"    />
        <result property="locationId"    column="location_id"    />
        <result property="building"    column="building"    />
        <result property="roomNumber"    column="room_number"    />
        <result property="capacity"    column="capacity"    />
        <result property="facilities"    column="facilities"    />
        <result property="hourlyRate"    column="hourly_rate"    />
        <result property="status"    column="status"    />
        <result property="adminId"    column="admin_id"    />
        <result property="createdAt"    column="created_at"    />
    </resultMap>

    <sql id="selectClassroomVo">
        select classroom_id, name, location_id, building, room_number, capacity, facilities, hourly_rate, status, admin_id, created_at from classroom
    </sql>

    <select id="selectClassroomList" parameterType="Classroom" resultMap="ClassroomResult">
        <include refid="selectClassroomVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="locationId != null  and locationId != ''"> and location_id = #{locationId}</if>
            <if test="building != null  and building != ''"> and building = #{building}</if>
            <if test="roomNumber != null  and roomNumber != ''"> and room_number = #{roomNumber}</if>
            <if test="capacity != null  and capacity != ''"> and capacity = #{capacity}</if>
            <if test="facilities != null  and facilities != ''"> and facilities = #{facilities}</if>
            <if test="hourlyRate != null "> and hourly_rate = #{hourlyRate}</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="adminId != null  and adminId != ''"> and admin_id = #{adminId}</if>
            <if test="createdAt != null "> and created_at = #{createdAt}</if>
        </where>
    </select>
    
    <select id="selectClassroomByClassroomId" parameterType="String" resultMap="ClassroomResult">
        <include refid="selectClassroomVo"/>
        where classroom_id = #{classroomId}
    </select>

    <insert id="insertClassroom" parameterType="Classroom" useGeneratedKeys="true" keyProperty="classroomId">
        insert into classroom
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="locationId != null and locationId != ''">location_id,</if>
            <if test="building != null and building != ''">building,</if>
            <if test="roomNumber != null and roomNumber != ''">room_number,</if>
            <if test="capacity != null and capacity != ''">capacity,</if>
            <if test="facilities != null and facilities != ''">facilities,</if>
            <if test="hourlyRate != null">hourly_rate,</if>
            <if test="status != null">status,</if>
            <if test="adminId != null and adminId != ''">admin_id,</if>
            <if test="createdAt != null">created_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="locationId != null and locationId != ''">#{locationId},</if>
            <if test="building != null and building != ''">#{building},</if>
            <if test="roomNumber != null and roomNumber != ''">#{roomNumber},</if>
            <if test="capacity != null and capacity != ''">#{capacity},</if>
            <if test="facilities != null and facilities != ''">#{facilities},</if>
            <if test="hourlyRate != null">#{hourlyRate},</if>
            <if test="status != null">#{status},</if>
            <if test="adminId != null and adminId != ''">#{adminId},</if>
            <if test="createdAt != null">#{createdAt},</if>
         </trim>
    </insert>

    <update id="updateClassroom" parameterType="Classroom">
        update classroom
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="locationId != null and locationId != ''">location_id = #{locationId},</if>
            <if test="building != null and building != ''">building = #{building},</if>
            <if test="roomNumber != null and roomNumber != ''">room_number = #{roomNumber},</if>
            <if test="capacity != null and capacity != ''">capacity = #{capacity},</if>
            <if test="facilities != null and facilities != ''">facilities = #{facilities},</if>
            <if test="hourlyRate != null">hourly_rate = #{hourlyRate},</if>
            <if test="status != null">status = #{status},</if>
            <if test="adminId != null and adminId != ''">admin_id = #{adminId},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
        </trim>
        where classroom_id = #{classroomId}
    </update>

    <delete id="deleteClassroomByClassroomId" parameterType="String">
        delete from classroom where classroom_id = #{classroomId}
    </delete>

    <delete id="deleteClassroomByClassroomIds" parameterType="String">
        delete from classroom where classroom_id in 
        <foreach item="classroomId" collection="array" open="(" separator="," close=")">
            #{classroomId}
        </foreach>
    </delete>
</mapper>